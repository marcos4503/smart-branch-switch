<Window x:Class="Smart_Branch_Switch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Smart_Branch_Switch"
        mc:Ignorable="d"
        Title="Smart Branch Switch: Running..." WindowStyle="ToolWindow" Icon="/Resources/window-icon-32px.png" ResizeMode="NoResize" SizeToContent="WidthAndHeight" Topmost="True">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="taskbarProgress" />
    </Window.TaskbarItemInfo>

    <Grid x:Name="windowRoot" HorizontalAlignment="Left" VerticalAlignment="Top" Width="390">
        <StackPanel VerticalAlignment="Top" Margin="8,8,8,8">
            <TextBlock x:Name="repoName" TextWrapping="Wrap" Text="placeholder-placeholder-placeholder" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <TextBlock x:Name="switchBranchContext" TextWrapping="Wrap" Text="placeholder-placeholder-placeholder &gt; placeholder-placeholder-placeholder" Foreground="#FF828282" VerticalAlignment="Top" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,4" FontSize="11"/>
            <Grid VerticalAlignment="Top" Height="8">
                <ProgressBar x:Name="progressSlider" Value="50"/>
                <ProgressBar x:Name="progressSliderFx" IsIndeterminate="True" BorderBrush="#00BCBCBC" Background="#00E6E6E6" Foreground="#FF008A19" HorizontalAlignment="Left" Width="374"/>
            </Grid>
            <StackPanel x:Name="logsPanel" Margin="0,8,0,0" VerticalAlignment="Top">
                <Border BorderBrush="#FF888888" BorderThickness="1" VerticalAlignment="Top">
                    <ScrollViewer x:Name="logsScrollView" VerticalAlignment="Top" Height="200">
                        <StackPanel x:Name="logsList" VerticalAlignment="Top" Margin="8,8,8,0"/>
                    </ScrollViewer>
                </Border>
                <Button x:Name="dismissBtn" Content="Button" Margin="0,8,0,0" VerticalAlignment="Top"/>
            </StackPanel>
        </StackPanel>
        <Border x:Name="highlightBlink" BorderBrush="#FFFFAF00" BorderThickness="2,2,2,2" Visibility="Collapsed"/>

    </Grid>
</Window>
